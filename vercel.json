{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/scripts",
      "dest": "/public/scripts.html"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "/public/script-detail.html"
    },
    {
      "src": "/snippets",
      "dest": "/public/snippets.html"
    },
    {
      "src": "/snippets/(.*)",
      "dest": "/public/snippet-detail.html"
    },
    {
      "src": "/downloads",
      "dest": "/public/downloads.html"
    },
    {
      "src": "/support",
      "dest": "/public/support.html"
    },
    {
      "src": "/support/ticket/(.*)",
      "dest": "/public/ticket-detail.html"
    },
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/updates",
      "dest": "/public/updates.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/partials/(.*)",
      "dest": "/public/partials/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
